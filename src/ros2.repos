############
repositories:
  ros2/examples:
    type: git
    url: https://github.com/ros2/examples.git
    version: humble
  ros2/demos:
    type: git
    url: https://github.com/ros2/demos.git
    version: humble
  book/ros2_journey_examples:
    type: git
    url: https://github.com/nirwester/ros2_journey_examples.git
    version: master